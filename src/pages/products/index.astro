---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Products"
  description="Kolosei's products — LinguistPro (Hebrew learning workspace), HDLE Premium (desktop lexicography), and EgorGenom (rare-disease genomics research)."
  wide={true}
>
  <h1>Products</h1>
  <p class="lead">
    Two shipping Hebrew products and one health-AI research vertical. All built and run by founder
    Peter Kolosei, all privacy-first, all using or planned to use Google Cloud.
  </p>

  <div class="grid-projects">
    {projects.map((p) => (
      <ProjectCard
        title={p.data.title}
        tagline={p.data.tagline}
        partOf={p.data.partOf}
        description={p.data.description}
        status={p.data.status}
        domain={p.data.domain}
        url={p.data.url}
        repo={p.data.repo}
        statusPage={p.data.statusPage}
        detailUrl={p.data.detailUrl}
        gcpServices={p.data.gcpServices}
      />
    ))}
  </div>

  <hr />
  <p class="small muted">
    Smaller experiments live in <code>github.com/SindromRadioSpb</code> directly. New products are added
    here as they reach a state worth pointing to publicly.
  </p>
</BaseLayout>
