---
interface Props {
  services?: string[];
  planned?: string[];
  compact?: boolean;
  label?: string;
}
const { services = [], planned = [], compact = false, label = 'Built on Google Cloud' } = Astro.props;
---
{(services.length > 0 || planned.length > 0) && (
  <div class={`gcp ${compact ? 'gcp-compact' : ''}`}>
    {services.length > 0 && (
      <>
        <p class="badge-label">{label}</p>
        <ul class="badge-row">
          {services.map((s) => <li class="badge">{s}</li>)}
        </ul>
      </>
    )}
    {planned.length > 0 && (
      <>
        <p class="badge-label">Planned / in evaluation</p>
        <ul class="badge-row">
          {planned.map((s) => <li class="badge badge-planned">{s}</li>)}
        </ul>
      </>
    )}
    {!compact && (
      <p class="small"><a href="/technology">How we use Google Cloud →</a></p>
    )}
  </div>
)}

<style>
  .gcp { margin: 1.5rem 0; }
  .gcp-compact { margin: 1rem 0; }
  .gcp .small { margin-top: 0.4rem; }
</style>
