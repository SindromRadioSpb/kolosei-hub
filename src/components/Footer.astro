---
const year = new Date().getFullYear();
const lang = (Astro.currentLocale ?? 'en') as 'en' | 'ru';
const p = (href: string) => (lang === 'ru' ? '/ru' + href : href);
const labels = {
  en: { technology: 'Technology', privacy: 'Privacy', terms: 'Terms', imprint: 'Imprint' },
  ru: { technology: 'Технологии', privacy: 'Конфиденциальность', terms: 'Условия', imprint: 'Импринт' },
}[lang];
---
<footer>
  <div class="inner">
    <p class="small muted">
      © {year} Kolosei · <a href="mailto:peter@kolosei.com">peter@kolosei.com</a> · <a href="https://github.com/SindromRadioSpb" rel="me">GitHub</a>
    </p>
    <p class="foot-links muted">
      <a href={p('/technology')}>{labels.technology}</a>
      <a href={p('/privacy')}>{labels.privacy}</a>
      <a href={p('/terms')}>{labels.terms}</a>
      <a href={p('/imprint')}>{labels.imprint}</a>
    </p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }
  .inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 1.5rem 1.25rem;
  }
  p { margin: 0; }
</style>
