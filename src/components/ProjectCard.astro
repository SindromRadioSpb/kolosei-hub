---
interface Props {
  title: string;
  description: string;
  status: 'active' | 'paused' | 'archived';
  domain?: string;
  url?: string;
  repo?: string;
  statusPage?: string;
}

const { title, description, status, domain, url, repo, statusPage } = Astro.props;
const statusLabel = { active: 'Active', paused: 'Paused', archived: 'Archived' }[status];
---
<article class="card">
  <header>
    <h3>{title}</h3>
    <span class={`status status-${status}`}>{statusLabel}</span>
  </header>
  <p>{description}</p>
  <footer class="links">
    {domain && <a href={`https://${domain}`}>{domain}</a>}
    {url && !domain && <a href={url}>{url.replace(/^https?:\/\//, '')}</a>}
    {repo && <a href={repo}>GitHub</a>}
    {statusPage && <a href={statusPage} title="Uptime status">↑ status</a>}
  </footer>
</article>

<style>
  .card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    background: var(--bg);
    transition: border-color 0.15s;
  }
  .card:hover { border-color: var(--fg-muted); }

  .card > header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  h3 { margin: 0; font-size: 1.1rem; }

  .status {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-weight: 500;
  }
  .status-active { background: var(--accent); color: white; }
  .status-paused { background: var(--bg-soft); color: var(--fg-muted); border: 1px solid var(--border); }
  .status-archived { background: var(--bg-soft); color: var(--fg-muted); border: 1px solid var(--border); }

  p { margin: 0 0 0.75rem; font-size: 0.95rem; }

  .links {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
</style>
